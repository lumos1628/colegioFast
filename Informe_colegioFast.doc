<tr><td>CUS-14</td><td>Gestionar matriculas</td><td>Admin</td><td>CRUD de alumnos, padres y relacion N-N. Matricula masiva.</td><td>alumnos, padres, alumno_padre, matriculas</td></tr>
<tr><td>CUS-15</td><td>Gestionar periodos</td><td>Admin</td><td>CRUD de periodos, cursos y asignaciones.</td><td>periodo_academicos, cursos, asignaciones</td></tr>
